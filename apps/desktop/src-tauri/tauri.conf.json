{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ParentScript",
  "version": "0.1.0",
  "identifier": "app.parentscript.desktop",
  "build": {
    "frontendDist": "../../../apps/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --workspace=apps/web",
    "beforeBuildCommand": "npm run build --workspace=apps/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ParentScript",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#fafafa"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Medical",
    "shortDescription": "Therapist-controlled parenting skills",
    "longDescription": "ParentScript — therapist-controlled parenting skills app, with role-based access for therapists and parents.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
