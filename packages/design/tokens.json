{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Amazed Labs Shared Tokens",
    "version": "1.1.0",
    "owners": ["mark@amazedlabs"],
    "description": "Shared primitives for Tono (professional/dark) and ParentScript (clinical/light). Two product skins, one token tree.",
    "notes": "Source of truth for both products. The canonical copy is /Users/Ezra/Projects/team/mark-deliverables/design-tokens.json — this file mirrors that and adds a few tonal accents (parentscript.danger.crisis, tono.feedback) that are surfaced in the In-the-Moment crisis card and the tone-preview component.",
    "tailwindPath": "apps/web/tailwind.config.ts",
    "cssVarsPath": "apps/web/src/index.css"
  },

  "global": {
    "font": {
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
      "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
    },

    "radius": {
      "none": "0px",
      "sm":   "8px",
      "md":  "12px",
      "lg":  "18px",
      "xl":  "24px",
      "2xl": "32px",
      "full": "9999px"
    },

    "space": {
      "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px",
      "16": "64px", "20": "80px", "24": "96px", "32": "128px"
    },

    "shadow": {
      "xs": "0 1px 2px rgba(0,0,0,0.04)",
      "sm": "0 2px 8px rgba(0,0,0,0.06)",
      "md": "0 8px 24px rgba(0,0,0,0.08)",
      "lg": "0 24px 64px rgba(0,0,0,0.12)",
      "focus": "0 0 0 3px rgba(99,102,241,0.35)",
      "focusTono": "0 0 0 3px rgba(168,85,247,0.35)",
      "focusDanger": "0 0 0 3px rgba(220,38,38,0.40)"
    },

    "motion": {
      "duration": {
        "instant":  "80ms",
        "fast":    "160ms",
        "normal":  "240ms",
        "slow":    "420ms",
        "deliberate": "640ms"
      },
      "ease": {
        "standard":  "cubic-bezier(0.2, 0.8, 0.2, 1)",
        "decelerate":"cubic-bezier(0, 0, 0.2, 1)",
        "accelerate":"cubic-bezier(0.4, 0, 1, 1)"
      },
      "reduced": "When prefers-reduced-motion: reduce, set durations to 1ms."
    },

    "z": {
      "base": 0, "raised": 10, "nav": 50, "overlay": 100,
      "modal": 200, "toast": 300, "crisis": 400
    },

    "feedback": {
      "crisis": {
        "bg":    "#FEE2E2",
        "bgStrong": "#FCA5A5",
        "border": "#DC2626",
        "ink":   "#7F1D1D",
        "shadow": "0 8px 32px rgba(220, 38, 38, 0.20)",
        "hotline": {
          "988": { "label": "988", "full": "Suicide & Crisis Lifeline — call or text 988" },
          "911": { "label": "911", "full": "Emergency services — call 911" },
          "childhelp": { "label": "1-800-422-4453", "full": "Childhelp National Child Abuse Hotline — 1-800-422-4453" }
        }
      }
    }
  },

  "products": {

    "tono": {
      "label": "Tono",
      "surface": "operate",
      "tone": "professional, premium, confident, dry-witty",
      "colorScheme": "dark",
      "themeColor": "#A855F7",

      "color": {
        "bg":         "#000000",
        "bgSoft":     "#0A0A0A",
        "bgCard":     "#111113",
        "bgElev":     "#16161A",
        "border":     "#1F1F23",
        "borderStrong":"#2A2A30",
        "text":       "#FFFFFF",
        "textSoft":   "#C9C9D1",
        "textSofter": "#9CA3AF",
        "muted":      "#6B7280",

        "accent":        "#A855F7",
        "accentHover":   "#9333EA",
        "accentSoft":    "rgba(168,85,247,0.12)",
        "accentSofter":  "rgba(168,85,247,0.06)",
        "accentLight":   "#D8B4FE",
        "accentGlow":    "rgba(168,85,247,0.35)",

        "danger":        "#EF4444",
        "warning":       "#F59E0B",
        "success":       "#10B981",
        "info":          "#3B82F6"
      },

      "toneAccents": {
        "warmer":   "#F472B6",
        "clearer":  "#38BDF8",
        "funnier":  "#FBBF24",
        "safer":    "#34D399"
      },

      "type": {
        "display":   ["48px", { "lineHeight": "56px", "letterSpacing": "-0.025em", "weight": 700 }],
        "h1":        ["36px", { "lineHeight": "44px", "letterSpacing": "-0.02em",  "weight": 700 }],
        "h2":        ["24px", { "lineHeight": "32px", "letterSpacing": "-0.01em",  "weight": 600 }],
        "h3":        ["18px", { "lineHeight": "26px", "weight": 600 }],
        "body":      ["15px", { "lineHeight": "24px", "weight": 400 }],
        "bodySm":    ["13px", { "lineHeight": "20px", "weight": 400 }],
        "caption":   ["12px", { "lineHeight": "16px", "weight": 500, "tracking": "0.02em" }],
        "mono":      ["13px", { "lineHeight": "20px", "weight": 400 }]
      }
    },

    "parentscript": {
      "label": "ParentScript",
      "surface": "monitor",
      "tone": "calm, clinical, reassuring, judgment-free",
      "colorScheme": "light",
      "themeColor": "#6366F1",

      "color": {
        "bg":         "#FFFFFF",
        "bgSoft":     "#FAFBFC",
        "bgCard":     "#FFFFFF",
        "bgElev":     "#FFFFFF",
        "border":     "#E5E7EB",
        "borderStrong":"#D1D5DB",
        "text":       "#111827",
        "textSoft":   "#4B5563",
        "textSofter": "#6B7280",
        "muted":      "#9CA3AF",

        "accent":        "#6366F1",
        "accentHover":   "#4F46E5",
        "accentSoft":    "#EEF2FF",
        "accentSofter":  "#F5F5FF",
        "accentLight":   "#A5B4FC",
        "accentInk":     "#3730A3",

        "warm":        "#F59E0B",
        "warmSoft":    "#FEF3C7",

        "success":     "#10B981",
        "successSoft": "#D1FAE5",
        "danger":      "#DC2626",
        "dangerSoft":  "#FEE2E2",
        "info":        "#0EA5E9",
        "infoSoft":    "#E0F2FE"
      },

      "type": {
        "display":   ["40px", { "lineHeight": "48px", "letterSpacing": "-0.02em", "weight": 700 }],
        "h1":        ["30px", { "lineHeight": "38px", "letterSpacing": "-0.01em", "weight": 700 }],
        "h2":        ["22px", { "lineHeight": "30px", "letterSpacing": "-0.005em","weight": 600 }],
        "h3":        ["18px", { "lineHeight": "26px", "weight": 600 }],
        "parentLg":  ["20px", { "lineHeight": "30px", "weight": 500 }],
        "body":      ["16px", { "lineHeight": "26px", "weight": 400 }],
        "bodySm":    ["14px", { "lineHeight": "22px", "weight": 400 }],
        "caption":   ["12px", { "lineHeight": "16px", "weight": 500, "tracking": "0.01em" }]
      }
    }
  },

  "components": {

    "button": {
      "padding": { "sm": "6px 12px", "md": "10px 18px", "lg": "14px 24px" },
      "radius": "global.radius.md",
      "minHeight": "44px",
      "variants": {
        "primary":   { "bg": "accent", "fg": "white", "hover": "accentHover" },
        "secondary": { "bg": "bgSoft", "fg": "text", "border": "border" },
        "ghost":     { "bg": "transparent", "fg": "textSoft", "hover": "text" },
        "danger":    { "bg": "danger", "fg": "white" },
        "oauthApple":   { "bg": "#000000", "fg": "#FFFFFF", "hover": "#1F1F23", "border": "#000000" },
        "oauthGoogle":  { "bg": "#FFFFFF", "fg": "#1F1F23", "hover": "#F9FAFB", "border": "#D1D5DB" },
        "oauthEmail":   { "bg": "transparent", "fg": "textSoft", "hover": "text", "border": "borderStrong" }
      }
    },

    "input": {
      "padding": "12px 14px",
      "radius": "global.radius.md",
      "border": "1px solid border",
      "focusRing": "shadow.focus",
      "minHeight": "44px"
    },

    "card": {
      "padding": "20px",
      "radius": "global.radius.lg",
      "bg": "bgCard",
      "border": "1px solid border",
      "shadow": "shadow.sm"
    },

    "crisisCard": {
      "padding": "20px",
      "radius": "global.radius.lg",
      "bg": "global.feedback.crisis.bg",
      "border": "2px solid global.feedback.crisis.border",
      "ink": "global.feedback.crisis.ink",
      "z": "z.crisis",
      "alwaysAbove": true
    },

    "toast": {
      "radius": "global.radius.md",
      "padding": "12px 16px",
      "duration": "4000ms",
      "z": "z.toast"
    }
  },

  "tailwindTheme": {
    "_comment": "Drop the contents of this object into tailwind.config.ts theme.extend. Consumed by both products.",
    "colors": {
      "tono": {
        "bg":            "#000000",
        "bg-soft":       "#0A0A0A",
        "bg-card":       "#111113",
        "border":        "#1F1F23",
        "text":          "#FFFFFF",
        "text-soft":     "#C9C9D1",
        "muted":         "#6B7280",
        "accent":        "#A855F7",
        "accent-soft":   "rgba(168,85,247,0.12)",
        "accent-glow":   "rgba(168,85,247,0.35)",
        "tone-warmer":   "#F472B6",
        "tone-clearer":  "#38BDF8",
        "tone-funnier":  "#FBBF24",
        "tone-safer":    "#34D399"
      },
      "parentscript": {
        "bg":            "#FFFFFF",
        "bg-soft":       "#FAFBFC",
        "border":        "#E5E7EB",
        "text":          "#111827",
        "text-soft":     "#4B5563",
        "muted":         "#9CA3AF",
        "accent":        "#6366F1",
        "accent-soft":   "#EEF2FF",
        "accent-ink":    "#3730A3",
        "warm":          "#F59E0B",
        "warm-soft":     "#FEF3C7",
        "success":       "#10B981",
        "success-soft":  "#D1FAE5",
        "crisis":        "#DC2626",
        "crisis-soft":   "#FEE2E2",
        "crisis-ink":    "#7F1D1D"
      }
    },
    "borderRadius": {
      "sm": "8px", "md": "12px", "lg": "18px", "xl": "24px", "2xl": "32px"
    },
    "fontFamily": {
      "sans":   ["'Inter'", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica", "Arial", "sans-serif"],
      "mono":   ["'JetBrains Mono'", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"]
    },
    "boxShadow": {
      "xs": "0 1px 2px rgba(0,0,0,0.04)",
      "sm": "0 2px 8px rgba(0,0,0,0.06)",
      "md": "0 8px 24px rgba(0,0,0,0.08)",
      "lg": "0 24px 64px rgba(0,0,0,0.12)",
      "focus-tono":        "0 0 0 3px rgba(168,85,247,0.35)",
      "focus-parentscript":"0 0 0 3px rgba(99,102,241,0.35)",
      "focus-danger":      "0 0 0 3px rgba(220,38,38,0.40)"
    },
    "transitionTimingFunction": {
      "tono-standard": "cubic-bezier(0.2, 0.8, 0.2, 1)"
    }
  }
}